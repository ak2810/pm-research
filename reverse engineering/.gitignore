# Local Parquet cache — synced from S3; never committed (large, regenerable)
output/cache/

# Model artifacts — large; commit hash+S3 URI to DECISIONS.md instead
output/models/

# Python build artifacts
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
.eggs/

# Tooling caches
.mypy_cache/
.ruff_cache/
.pytest_cache/
.ipynb_checkpoints/

# Scratch notebooks — personal exploration
notebooks/scratch/

# Environment and secrets — never committed
.env
*.pem
*.key

# Large Parquet outputs (>50MB) — record hash+S3 URI in DECISIONS.md
# Smaller outputs (<50MB) may be committed
output/tables/*.parquet

# OS artifacts
.DS_Store
Thumbs.db
