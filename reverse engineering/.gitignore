# Local Parquet cache — synced from S3; never committed (large, regenerable)
output/cache/

# Model artifacts — large; commit hash+S3 URI to DECISIONS.md instead
output/models/

# Python build artifacts
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
.eggs/

# Tooling caches
.mypy_cache/
.ruff_cache/
.pytest_cache/
.ipynb_checkpoints/

# Scratch notebooks — personal exploration
notebooks/scratch/

# Environment and secrets — never committed
.env
*.pem
*.key

# Parquet outputs — regenerable from S3; record hash+S3 URI in DECISIONS.md
# (pre-refactor path kept for safety; new dual-target paths below)
output/tables/*.parquet
output/ohanism/cache/
output/ohanism/tables/*.parquet
output/ohanism/models/*.pkl
output/ohanism/models/*.pt
output/bot2855/cache/
output/bot2855/tables/*.parquet
output/bot2855/models/*.pkl
output/bot2855/models/*.pt

# OS artifacts
.DS_Store
Thumbs.db
