# ── AWS ──────────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=eu-west-1
S3_BUCKET=pm-research-data

# ── Polygon RPC ───────────────────────────────────────────────────────────────
POLYGON_WSS_URL=wss://polygon-mainnet.g.alchemy.com/v2/<KEY>
POLYGON_HTTPS_URL=https://polygon-mainnet.g.alchemy.com/v2/<KEY>
# Max blocks per eth_getLogs call (Alchemy default 2000, some providers 10000)
ALCHEMY_BLOCK_RANGE_LIMIT=2000

# ── Polygonscan ───────────────────────────────────────────────────────────────
POLYGONSCAN_API_KEY=

# ── Storage paths ─────────────────────────────────────────────────────────────
DATA_DIR=/var/pm-research/data
STATE_DIR=/var/pm-research/state
LOG_DIR=/var/pm-research/logs

# ── Alerting ──────────────────────────────────────────────────────────────────
DISCORD_WEBHOOK_URL=
HEALTHCHECKS_URL=

# ── Collector tuning ──────────────────────────────────────────────────────────
# Gamma discovery interval seconds (default 30)
GAMMA_DISCOVERY_INTERVAL_S=30
# Max age of a market to track (hours from endDate, default 6)
MARKET_MAX_AGE_HOURS=6
# Binance reconnect before 24h limit (seconds, default 82800 = 23h)
BINANCE_RECONNECT_AT_S=82800

# ── Clock tolerance ───────────────────────────────────────────────────────────
# Max allowed NTP drift before startup fails (milliseconds)
MAX_NTP_DRIFT_MS=50
